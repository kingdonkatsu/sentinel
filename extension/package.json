{
  "name": "sentinel-extension",
  "version": "0.1.0",
  "private": true,
  "description": "Privacy-first mental health triage for youth workers",
  "scripts": {
    "dev": "vite",
    "build:raw": "tsc && vite build",
    "build": "npm run build:raw && node ./scripts/flush-redis.mjs",
    "test:unit": "tsc -p tsconfig.test.json && node --test tests/*.test.cjs"
  },
  "dependencies": {
    "@tensorflow/tfjs": "^4.22.0",
    "@vladmandic/face-api": "^1.7.14",
    "@xenova/transformers": "^2.17.2",
    "sentiment": "^5.0.2"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "@types/chrome": "^0.0.268",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  }
}
